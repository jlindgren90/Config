#!/bin/bash

[[ -f ~/.profile ]] && . ~/.profile
[[ -f ~/.bashrc ]] && . ~/.bashrc

if [ -z "$DISPLAY" ] && [ -z "$WAYLAND_DISPLAY" ] && [ "$XDG_VTNR" = 1 ] && command -v labwc >/dev/null ; then
  proptest -M i915 -D /dev/dri/card0 81 connector 83 2
  exec labwc >"$XDG_RUNTIME_DIR"/labwc.log 2>&1
fi
